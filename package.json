{
  "name": "ralph",
  "version": "1.0.0",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "ralph": "src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --compile --outfile ralph",
    "build:linux-x64": "bun build src/index.ts --compile --target bun-linux-x64 --outfile ralph-linux-x64",
    "build:linux-arm64": "bun build src/index.ts --compile --target bun-linux-arm64 --outfile ralph-linux-arm64",
    "build:darwin-x64": "bun build src/index.ts --compile --target bun-darwin-x64 --outfile ralph-darwin-x64",
    "build:darwin-arm64": "bun build src/index.ts --compile --target bun-darwin-arm64 --outfile ralph-darwin-arm64",
    "build:windows-x64": "bun build src/index.ts --compile --target bun-windows-x64 --outfile ralph-windows-x64.exe",
    "build:all": "bun run build:linux-x64 && bun run build:linux-arm64 && bun run build:darwin-x64 && bun run build:darwin-arm64 && bun run build:windows-x64",
    "embed-templates": "bun run scripts/embed-templates.ts",
    "prebuild": "bun run embed-templates",
    "test": "bun test",
    "lint": "bunx @biomejs/biome check src/",
    "lint:fix": "bunx @biomejs/biome check --write src/",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "@clack/prompts": "^0.10.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "marked": "^15.0.0",
    "marked-terminal": "^7.3.0",
    "ora": "^8.2.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "^1.2.0",
    "typescript": "^5.7.0"
  }
}
